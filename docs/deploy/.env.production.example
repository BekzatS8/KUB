# Backend (required for signing links in production)
GIN_MODE=release

# Frontend/public URLs (must be public, non-localhost URLs)
FRONTEND_APP_URL=https://kubcrm.kz
PUBLIC_BASE_URL=https://kubcrm.kz
SIGN_EMAIL_VERIFY_BASE_URL=https://kubcrm.kz
SIGN_BASE_URL=https://kubcrm.kz/sign

# Signing security
SIGN_EMAIL_TOKEN_PEPPER=replace-with-strong-random-secret
SIGN_PUBLIC_TOKEN_PEPPER=replace-with-strong-random-secret
SIGN_EMAIL_TTL=30m
SIGN_SESSION_TTL_MINUTES=30
