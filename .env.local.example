GIN_MODE=debug
CONFIG_PATH=/opt/turcompany/config/config.local.yaml

# Database
DATABASE_URL=postgres://turcompany:turcompany@postgres:5432/turcompany?sslmode=disable
POSTGRES_USER=turcompany
POSTGRES_PASSWORD=turcompany
POSTGRES_DB=turcompany
POSTGRES_PORT=5432

# App security (dev only)
JWT_SECRET=dev-jwt-secret-change-me

# Email (dev defaults are intentionally fake)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASSWORD=dev
EMAIL_FROM=dev@localhost

# Signing flow
SIGN_BASE_URL=http://localhost:4000/sign
SIGN_CONFIRM_POLICY=ANY
SIGN_EMAIL_VERIFY_BASE_URL=http://localhost:4000
SIGN_EMAIL_TOKEN_PEPPER=dev-sign-pepper
SIGN_PUBLIC_TOKEN_PEPPER=dev-sign-public-pepper
SIGN_SESSION_TTL_MINUTES=30

# Telegram/Wazzup integrations (disabled by default in local)
TELEGRAM_ENABLE=false
TELEGRAM_APITOKEN=
TELEGRAM_WEBHOOK_URL=
WAZZUP_ENABLE=false
WAZZUP_API_BASE_URL=https://api.wazzup24.com
WAZZUP_API_TOKEN=
WAZZUP_CHANNEL_ID=
WAZZUP_WEBHOOK_VERIFY_TOKEN=
WAZZUP_WEBHOOK_BASE_URL=http://localhost:4000
WAZZUP_REQUEST_TIMEOUT_SEC=10
WAZZUP_RETRY_COUNT=1
WAZZUP_RETRY_DELAY_MS=300

# Ports
API_PORT=4000

# DB wait settings
DB_WAIT_RETRIES=30
DB_WAIT_INTERVAL=2
