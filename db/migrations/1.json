{
  "info": {
    "_postman_id": "c0f02f04-1c7a-44cd-8a28-93ecb3df4c79",
    "name": "Turcompany Auth & Password Reset",
    "description": "Коллекция Postman для проверки регистрации, логина, обновления токенов и полного флоу сброса пароля.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register (new user)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const ts = Date.now();",
              "pm.environment.set('ts', ts);",
              "pm.environment.set('email', `reset_user_${ts}@example.com`);",
              "pm.environment.set('password', `Passw0rd!${ts}`);",
              "pm.environment.set('phone', `+7700${(ts % 10000000).toString().padStart(7, '0')}`);",
              "pm.environment.set('company_name', pm.environment.get('company_name') || 'Test Company');",
              "pm.environment.set('bin_iin', pm.environment.get('bin_iin') || '123456789012');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.environment.set('user_id', res.user?.id);",
              "pm.environment.set('password', pm.environment.get('password'));",
              "pm.environment.set('email', res.user?.email || pm.environment.get('email'));",
              "pm.test('Registered user returned', function () { pm.expect(res.user?.id).to.be.a('number'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company_name\": \"{{company_name}}\",\n  \"bin_iin\": \"{{bin_iin}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"{{phone}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "register"
          ]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.environment.set('access_token', res.tokens?.access_token);",
              "pm.environment.set('refresh_token', res.tokens?.refresh_token);",
              "pm.environment.set('user_id', res.user?.id);",
              "pm.test('Login succeeded', function () { pm.expect(res.tokens?.access_token).to.be.a('string'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Refresh token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.environment.set('access_token', res.tokens?.access_token);",
              "pm.environment.set('refresh_token', res.tokens?.refresh_token);",
              "pm.test('Refresh issued new tokens', function () { pm.expect(res.tokens?.refresh_token).to.be.a('string'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/refresh",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "refresh"
          ]
        }
      }
    },
    {
      "name": "Forgot password (send reset link)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/forgot-password",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "forgot-password"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Reset password (apply token)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const newPw = `NewPassw0rd!${Date.now()}`;",
              "pm.environment.set('new_password', newPw);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Reset password success message', function () {",
              "  const res = pm.response.json();",
              "  pm.expect(res.message).to.match(/успешно измен/iu);",
              "});",
              "pm.environment.set('password', pm.environment.get('new_password'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{reset_token}}\",\n  \"new_password\": \"{{new_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/reset-password",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "reset-password"
          ]
        }
      }
    },
    {
      "name": "Login (after reset)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.environment.set('access_token', res.tokens?.access_token);",
              "pm.environment.set('refresh_token', res.tokens?.refresh_token);",
              "pm.test('Login with new password works', function () { pm.expect(res.tokens?.access_token).to.be.a('string'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": ["{{base_url}}"],
          "path": ["auth","login"]
        }
      }
    },
    {
      "name": "Get my profile (JWT)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "type": "text",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/users/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users",
            "me"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    }
  ]
}