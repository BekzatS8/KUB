                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Лид от клиента {{clientId}}\",\n  \"description\": \"Первичный интерес к программе.\",\n  \"status\": \"new\"\n}"
            },
            "url": "{{baseUrl}}/leads"
          },
          "response": [],
