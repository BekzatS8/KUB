    },
    {
      "name": "5. Deals",
      "item": [
        {
          "name": "Create Deal (/deals)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lead_id\": \"{{leadId}}\",\n  \"client_id\": \"{{clientId}}\",\n  \"amount\": \"1600000\",\n  \"currency\": \"KZT\",\n  \"status\": \"new\"\n}"
            },
            "url": "{{baseUrl}}/deals"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  if (data && data.id) {",
                  "    pm.collectionVariables.set('dealId', data.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
