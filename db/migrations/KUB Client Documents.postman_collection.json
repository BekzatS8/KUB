{
  "info": {
    "_postman_id": "00000000-0000-0000-0000-000000000001",
    "name": "KUB API – Full Flow (User → Client → Lead → Deal → Docs)",
    "description": "Полный сценарий от логина до генерации документов: пользователи, клиенты, лиды, сделки и документы.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login (получить access_token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/login"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  if (data.tokens && data.tokens.access_token) {",
                  "    pm.collectionVariables.set('accessToken', data.tokens.access_token);",
                  "  }",
                  "  if (data.tokens && data.tokens.refresh_token) {",
                  "    pm.collectionVariables.set('refreshToken', data.tokens.refresh_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh token (/refresh)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/refresh"
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Users (admin)",
      "item": [
        {
          "name": "Create User (admin → /users)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"Test Company\",\n  \"bin_iin\": \"000000000000\",\n  \"email\": \"sales1@example.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"+77000000001\",\n  \"role_id\": 10\n}"
            },
            "url": "{{baseUrl}}/users"
          },
          "response": []
        },
        {
          "name": "Get My Profile (/users/me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/users/me"
          },
          "response": []
        }
      ]
    },
    {
