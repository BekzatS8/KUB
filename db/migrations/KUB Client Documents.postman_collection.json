              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ООО Ромашка\",\n  \"bin_iin\": \"123456789012\",\n  \"address\": \"г. Алматы, ул. Клиентская, д. 5\",\n  \"contact_info\": \"+77001234567, client@example.com\"\n}"
            },
            "url": "{{baseUrl}}/clients"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var data = pm.response.json();",
                  "  if (data && data.id) {",
                  "    pm.collectionVariables.set('clientId', data.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Leads",
