GIN_MODE=release
CONFIG_PATH=/opt/turcompany/config/config.yaml

# Database
DATABASE_URL=postgres://turcompany:CHANGE_ME@postgres:5432/turcompany?sslmode=disable
POSTGRES_USER=turcompany
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=turcompany
POSTGRES_PORT=5432

# App security
JWT_SECRET=CHANGE_ME

# Email (used in config.yaml, can be templated via envsubst)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@example.com

# Signing flow
SIGN_BASE_URL=https://example.com/sign
SIGN_CONFIRM_POLICY=ANY
SIGN_EMAIL_VERIFY_BASE_URL=https://example.com
SIGN_EMAIL_TOKEN_PEPPER=CHANGE_ME
SIGN_PUBLIC_TOKEN_PEPPER=CHANGE_ME
SIGN_SESSION_TTL_MINUTES=30

# Telegram
TELEGRAM_ENABLE=false
TELEGRAM_APITOKEN=CHANGE_ME
TELEGRAM_WEBHOOK_URL=https://example.com/telegram/webhook

# Wazzup (WhatsApp) - keep real token only in runtime secrets
WAZZUP_ENABLE=false
WAZZUP_API_BASE_URL=https://api.wazzup24.com
WAZZUP_API_TOKEN=CHANGE_ME
WAZZUP_CHANNEL_ID=
WAZZUP_WEBHOOK_VERIFY_TOKEN=CHANGE_ME
WAZZUP_WEBHOOK_BASE_URL=https://api.example.com
WAZZUP_REQUEST_TIMEOUT_SEC=10
WAZZUP_RETRY_COUNT=1
WAZZUP_RETRY_DELAY_MS=300

# Redis (optional)
REDIS_PORT=6379

# Compose ports
API_PORT=4000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# DB wait settings
DB_WAIT_RETRIES=30
DB_WAIT_INTERVAL=2
