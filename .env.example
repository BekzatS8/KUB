# Core
GIN_MODE=release
API_PORT=4000
CONFIG_PATH=/opt/turcompany/config/config.yaml
JWT_SECRET=REPLACE_WITH_STRONG_32B_PLUS_SECRET
DATABASE_URL=postgres://kub_user:REPLACE_DB_PASSWORD@postgres:5432/kub?sslmode=require

# Optional Postgres split variables (used when DATABASE_URL is not set)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kub_user
POSTGRES_PASSWORD=REPLACE_DB_PASSWORD
POSTGRES_DB=kub

# Telegram
TELEGRAM_ENABLE=false
TELEGRAM_BOT_TOKEN=REPLACE_TELEGRAM_BOT_TOKEN
TELEGRAM_APITOKEN=
TELEGRAM_WEBHOOK_ENABLED=true
TELEGRAM_WEBHOOK_URL=https://example.com/integrations/telegram/webhook

# SMTP / Email signing
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=REPLACE_SMTP_PASSWORD
EMAIL_FROM=noreply@example.com
SMTP_FROM=noreply@example.com
SIGN_EMAIL_TOKEN_PEPPER=REPLACE_SIGN_EMAIL_TOKEN_PEPPER
SIGN_EMAIL_VERIFY_BASE_URL=https://example.com
SIGN_BASE_URL=https://example.com/sign

# Smoke test account (optional)
SMOKE_LOGIN_EMAIL=
SMOKE_LOGIN_PASSWORD=
SMOKE_SIGN_DOC_ID=
SMOKE_EMAIL_TOKEN=
SMOKE_EMAIL_CODE=
SKIP_EMAIL_SMOKE=1
