GIN_MODE=release
CONFIG_PATH=/opt/turcompany/config/config.yaml

# Database
DATABASE_URL=postgres://turcompany:CHANGE_ME@postgres:5432/turcompany?sslmode=disable
POSTGRES_USER=turcompany
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=turcompany
POSTGRES_PORT=5432

# App security
JWT_SECRET=CHANGE_ME

# Email (used in config.yaml, can be templated via envsubst)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@example.com

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_ACCESS_TOKEN=CHANGE_ME
WHATSAPP_TEMPLATE_CODE_NAME=auth_sign_code
WHATSAPP_TEMPLATE_LINK_NAME=util_sign_link
WHATSAPP_TEMPLATE_LANG=ru
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com/v20.0
WHATSAPP_ENABLED=true
WHATSAPP_DRY_RUN=false

# Signing flow
SIGN_BASE_URL=https://example.com/sign
SIGN_CONFIRM_POLICY=ANY
SIGN_EMAIL_VERIFY_BASE_URL=https://example.com

# Telegram
TELEGRAM_APITOKEN=CHANGE_ME
TELEGRAM_WEBHOOK_URL=https://example.com/telegram/webhook

# Redis (optional)
REDIS_PORT=6379

# Compose ports
API_PORT=4000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# DB wait settings
DB_WAIT_RETRIES=30
DB_WAIT_INTERVAL=2
